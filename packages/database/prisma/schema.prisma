// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  githubId      Int?           @unique
  login         String?
  name          String?
  avatarUrl     String?
  organizations Organization[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Organization {
  id               String              @id @default(uuid())
  name             String
  githubId         Int                 @unique
  installationId   Int?                @unique
  avatarUrl        String?
  users            User[]
  repositories     Repository[]
  installation     GitHubInstallation? @relation(fields: [installationId], references: [githubId])
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
}

model GitHubInstallation {
  id            String         @id @default(uuid())
  githubId      Int            @unique // The installation_id from GitHub
  accountName   String
  accountType   String         // Organization or User
  targetId      Int            // The ID of the org or user on GitHub
  organizations Organization[]
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Repository {
  id             String           @id @default(uuid())
  name           String
  fullName       String           @unique
  githubId       Int              @unique
  defaultBranch  String           @default("main")
  isPrivate      Boolean          @default(false)
  isActive       Boolean          @default(true)
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id])
  pullRequests   PullRequest[]
  rules          RepositoryRule[]
  metrics        ReviewMetric[]
  lastSyncedAt   DateTime         @default(now())
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model PullRequest {
  id             String         @id @default(uuid())
  number         Int
  githubId       Int            @unique
  title          String
  state          String         // open, closed, merged
  authorHandle   String?
  baseBranch     String?
  headBranch     String?
  headSha        String?
  htmlUrl        String?
  repositoryId   String
  repository     Repository     @relation(fields: [repositoryId], references: [id])
  reviews        ReviewResult[]
  jobs           AnalysisJob[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([repositoryId, number])
}

model AnalysisJob {
  id             String       @id @default(uuid())
  pullRequestId  String
  pullRequest    PullRequest  @relation(fields: [pullRequestId], references: [id])
  status         String       // QUEUED, PROCESSING, COMPLETED, FAILED
  step           String?      // FETCHING_DIFF, CHUNKING, AI_ANALYSIS, POSTING
  workerId       String?
  attempts       Int          @default(0)
  error          String?      @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model ReviewResult {
  id            String          @id @default(uuid())
  pullRequestId String?
  pullRequest   PullRequest?    @relation(fields: [pullRequestId], references: [id])
  commitSha     String?
  summary       String?         @db.Text
  severityScore Int?
  status        String          @default("PENDING") // PENDING, COMPLETED, FAILED
  error         String?         @db.Text
  comments      ReviewComment[]
  usageLogs     AiUsageLog[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model ReviewComment {
  id             String       @id @default(uuid())
  reviewResultId String
  reviewResult   ReviewResult @relation(fields: [reviewResultId], references: [id])
  filePath       String
  lineNumber     Int
  content        String       @db.Text
  suggestion     String?      @db.Text // AI generated code fix
  severity       String       // HIGH, MEDIUM, LOW
  type           String       // SECURITY, PERFORMANCE, STYLE
  diffHunk       String?      @db.Text
  externalId     String?      // GitHub Comment ID
  createdAt      DateTime     @default(now())
}

model RepositoryRule {
  id             String     @id @default(uuid())
  repositoryId   String
  repository     Repository @relation(fields: [repositoryId], references: [id])
  name           String
  description    String?
  pattern        String?    @db.Text
  type           String     @default("AI") // REGEX, AI, LINT
  config         Json?
  isEnabled      Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model AiUsageLog {
  id               String        @id @default(uuid())
  reviewResultId   String?
  reviewResult     ReviewResult? @relation(fields: [reviewResultId], references: [id])
  modelName        String
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  latencyMs        Int
  requestId        String?
  cost             Float?
  createdAt        DateTime      @default(now())
}

model ReviewMetric {
  id             String     @id @default(uuid())
  repositoryId   String
  repository     Repository @relation(fields: [repositoryId], references: [id])
  date           DateTime   @default(now())
  highSeverity   Int        @default(0)
  mediumSeverity Int        @default(0)
  lowSeverity    Int        @default(0)
  totalTokens    Int        @default(0)
}

model PromptTemplate {
  id        String   @id @default(uuid())
  name      String   @unique
  content   String   @db.Text
  version   Int      @default(1)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AiSettings {
  id                String   @id @default(uuid())
  openRouterKey     String?
  defaultModel      String   @default("deepseek/deepseek-v4-flash:free")
  fallbackModel     String   @default("arcee-ai/trinity-large-thinking:free")
  isFallbackEnabled Boolean  @default(true)
  temperature       Float    @default(0.1)
  maxTokens         Int      @default(2048)
  systemPrompt      String   @default("You are an elite, highly specialized AI code auditor. Analyze the pull request diff for:\n1. Critical security bugs and OWASP vulnerabilities.\n2. Major execution hotpaths and latency bottlenecks.\n3. Logical deadlocks, edge cases, and standard cleanups.\n\nAdopt a clean, direct, and constructive technical persona. Offer actionable, production-grade refactored code blocks in your responses.") @db.Text
  bypassSignature   Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
