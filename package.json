{
  "name": "mergemind",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:generate": "npm run generate -w @mergemind/database",
    "db:migrate:dev": "npm run migrate:dev -w @mergemind/database",
    "db:migrate:deploy": "npm run migrate:deploy -w @mergemind/database",
    "db:push": "npm run push -w @mergemind/database",
    "db:seed": "npm run seed -w @mergemind/database",
    "db:studio": "npm run studio -w @mergemind/database",
    "db:reset": "npm run reset -w @mergemind/database"
  },
  "devDependencies": {
    "turbo": "latest",
    "prettier": "^3.4.2"
  },
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
