{
  "name": "mergemind",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:generate": "dotenv -e .env -- npm run generate -w @mergemind/database",
    "db:migrate:dev": "dotenv -e .env -- npm run migrate:dev -w @mergemind/database",
    "db:migrate:deploy": "dotenv -e .env -- npm run migrate:deploy -w @mergemind/database",
    "db:seed": "dotenv -e .env -- npm run seed -w @mergemind/database",
    "db:studio": "dotenv -e .env -- npm run studio -w @mergemind/database",
    "db:reset": "dotenv -e .env -- npm run reset -w @mergemind/database"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.4.2",
    "turbo": "latest"
  },
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
